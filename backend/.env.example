ANTHROPIC_API_KEY=your_key_here
DATABASE_URL=sqlite:///./prediction_tracker.db

# Optional: enables YouTube guest appearance search (YouTube Data API v3)
# Get a key at https://console.cloud.google.com — enable "YouTube Data API v3"
YOUTUBE_API_KEY=

# Optional: enables podcast guest appearance search via Listen Notes
# Get a key at https://www.listennotes.com/api/
LISTENNOTES_API_KEY=
